          "task_id": "paper_simulation_lab.daily_run",
          "job_id": "paper_simulation_daily_run",
          "display_name": "模拟交易日运行",
          "trigger_type": "post_publish_trigger",
          "phase": "publish_gated_jobs",
          "entrypoint": "neotrade3.labs.runtime:LabRuntimeAdapter.run_job",
          "depends_on": ["data_control.publish"],
          "requires_publish_status": true,
          "outputs": ["lab_run_summary", "paper_simulation_positions"],
          "artifacts": ["paper_simulation_positions"],
          "health_checks": ["job_registration_present", "artifact_contract_present"]
        }
      ],
      "artifacts": [
        {
          "artifact_id": "paper_simulation_positions",
          "path": "var/artifacts/labs/paper_simulation_lab/positions.json",
          "description": "Paper simulation daily position snapshot contract."
        }
      ],
      "health_checks": [
        {
          "check_id": "job_registration_present",
          "description": "Daily job contract must exist for the lab."
        },
        {
          "check_id": "artifact_contract_present",
          "description": "Declared artifacts must have matching contract definitions."
        }
      ],
      "learning_inputs": ["daily_metrics"]
    },
