{
  "version": 1,
  "description": "Active NeoTrade3 lab registry for runtime scheduling and artifact contracts",
  "labs": [
    {
      "lab_id": "cup_handle_lab",
      "display_name": "杯柄实验室",
      "domain": "pattern_research",
      "owner": "unassigned",
      "enabled": true,
      "input_dependencies": ["published_daily_data"],
      "daily_jobs": [
        {
          "task_id": "cup_handle_lab.daily_review",
          "job_id": "cup_handle_daily_review",
          "display_name": "杯柄日评估",
          "trigger_type": "daily_lab_trigger",
          "phase": "daily_lab_jobs",
          "entrypoint": "neotrade3.labs.runtime:LabRuntimeAdapter.run_job",
          "depends_on": [],
          "requires_publish_status": false,
          "outputs": ["lab_run_summary", "cup_handle_daily_report"],
          "artifacts": ["cup_handle_daily_report"],
          "health_checks": ["job_registration_present", "artifact_contract_present"]
        }
      ],
      "artifacts": [
        {
          "artifact_id": "cup_handle_daily_report",
          "path": "var/artifacts/labs/cup_handle_lab/daily_report.json",
          "description": "Cup-handle daily evaluation output contract."
        }
      ],
      "health_checks": [
        {
          "check_id": "job_registration_present",
          "description": "Daily job contract must exist for the lab."
        },
        {
          "check_id": "artifact_contract_present",
          "description": "Declared artifacts must have matching contract definitions."
        }
      ],
      "learning_inputs": ["daily_metrics"]
    },
    {
      "lab_id": "paper_simulation_lab",
      "display_name": "量化模拟交易实验室",
      "domain": "simulation",
      "owner": "unassigned",
      "enabled": true,
      "input_dependencies": ["published_daily_data"],
